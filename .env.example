# FOCUS Counseling Platform - Environment Variables Template
# Copy this to .env for local development
# Render will automatically set DATABASE_URL in production

# Database Configuration
# For local development (SQLite):
# DATABASE_URL=

# For production (Render PostgreSQL):
# DATABASE_URL=postgresql://username:password@host:port/database

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Render automatically provides these in production:
# DATABASE_URL - PostgreSQL connection string
# PORT - Render port (usually 10000)
